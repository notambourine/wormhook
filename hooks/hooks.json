{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "if": "Bash(npm *)|Bash(npx *)|Bash(pnpm *)|Bash(yarn *)|Bash(bun *)|Bash(node *)",
            "timeout": 300,
            "statusMessage": "wormhook: scanning for supply-chain malware..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "if": "Bash(npm *)|Bash(pnpm *)|Bash(yarn *)|Bash(bun *)",
            "timeout": 300,
            "statusMessage": "wormhook: post-install supply-chain scan..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "if": "Bash(git pull*)|Bash(git merge*)|Bash(git checkout*)|Bash(git switch*)|Bash(git rebase*)",
            "timeout": 300,
            "statusMessage": "wormhook: post-checkout supply-chain scan..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "timeout": 300,
            "statusMessage": "wormhook: scanning node_modules for supply-chain malware..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
