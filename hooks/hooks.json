{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "if": "Bash(npm *)|Bash(npx *)|Bash(pnpm *)|Bash(yarn *)|Bash(bun *)|Bash(node *)|Bash(pip *)|Bash(pip3 *)|Bash(pipx *)|Bash(uv *)|Bash(python *)|Bash(python3 *)",
            "timeout": 300,
            "statusMessage": "wormhook: scanning for supply-chain malware..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "if": "Bash(npm *)|Bash(pnpm *)|Bash(yarn *)|Bash(bun *)|Bash(git pull*)|Bash(git merge*)|Bash(git checkout*)|Bash(git switch*)|Bash(git rebase*)|Bash(pip *)|Bash(pip3 *)|Bash(pipx *)|Bash(uv *)",
            "timeout": 300,
            "statusMessage": "wormhook: post-op supply-chain scan..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "timeout": 15,
            "statusMessage": "wormhook: continuous supply-chain monitor..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/wormhook.sh\"",
            "timeout": 300,
            "statusMessage": "wormhook: scanning node_modules for supply-chain malware..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/deps.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/firewall.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/coverage.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/cicd.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/drift.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/exposure.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/doctor/shellguard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
